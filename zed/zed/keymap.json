// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-shift-m": "diagnostics::DeployCurrentFile",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-d": [
        "editor::DeleteToNextWordEnd",
        {
          "ignore_newlines": false,
          "ignore_brackets": false,
        },
      ],
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "alt-delete": [
        "editor::DeleteToNextWordEnd",
        {
          "ignore_newlines": false,
          "ignore_brackets": false,
        },
      ],
    },
  },
  {
    "context": "ProjectPanel",
    "unbind": {
      "alt-cmd-shift-f": "project_panel::NewSearchInDirectory",
    },
  },
  {
    "bindings": {
      "alt-cmd-shift-f": "text_finder::Toggle",
    },
  },
  // Vim
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "space w": "workspace::Save",
      "space s g": "text_finder::Toggle",
    },
  },
  {
    "context": "(vim_mode == normal || vim_mode == select) && !menu",
    "bindings": {
      // fF/tT
      "f": ["vim::PushFindForward", { "before": false, "multiline": true }],
      "t": ["vim::PushFindForward", { "before": true, "multiline": true }],
      "shift-f": [
        "vim::PushFindBackward",
        { "after": false, "multiline": true },
      ],
      "shift-t": [
        "vim::PushFindBackward",
        { "after": true, "multiline": true },
      ],
      // Diagnostics
      "space s d": "diagnostics::DeployCurrentFile",
      "space s D": "diagnostics::Deploy",

      "g w": "vim::HelixJumpToWord",
      // Pickers
      "space f f": "file_finder::Toggle",
      "space s S": "project_symbols::Toggle",
      "space s s": "outline::Toggle",
      "space s c": "command_palette::Toggle",

      // Debugging
      "space shift-g c": "debugger::Continue",
      "space shift-g h": "debugger::Pause",
      "space shift-g r": "debugger::Restart",
      "space shift-g l": "debugger::Start",
      "space shift-g i": "debugger::StepInto",
      "space shift-g o": "debugger::StepOut",
      "space shift-g n": "debugger::StepOver",
      "space shift-g t": "debugger::Stop",
      "space y": "editor::Copy",
      "space shift-g ctrl-l": "editor::EditLogBreakpoint",
    },
  },
  {
    "context": "!Editor && !Terminal",
    "bindings": {
      "space f f": "file_finder::Toggle"
    }
  },
  {
    "context": "!Editor && !Terminal",
    "unbind": {
      "space f": "file_finder::Toggle"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "space f": "file_finder::Toggle"
    }
  }
]
