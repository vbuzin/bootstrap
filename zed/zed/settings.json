// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "semantic_tokens": "off",
  "completion_menu_item_kind": "symbol",
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "vim_mode": true,
  "code_lens": "on",
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 340.0,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "base_keymap": "VSCode",
  "buffer_line_height": "comfortable",
  "status_bar": {
    "show_active_file": false,
  },
  "edit_predictions": {
    "allow_data_collection": "no",
    "mode": "subtle",
  },
  "icon_theme": "Zed (Default)",
  "languages": {
    "Rust": {
      "line_ending": "enforce_lf",
      "inlay_hints": {},
    },
    "Markdown": {
      "remove_trailing_whitespace_on_save": true,
      "format_on_save": "on",
    },
  },
  "text_rendering_mode": "platform_default",
  "agent": {
    "dock": "left",
    "default_profile": "write",
    "default_model": {
      "provider": "x_ai",
      "model": "grok-4.3",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
    "default_width": 340.0,
  },
  "ui_font_weight": 300.0,
  "buffer_font_weight": 300.0,
  "project_panel": {
    "dock": "right",
    "default_width": 340.0,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": false,
  },
  "use_smartcase_search": true,
  "indent_guides": {
    "coloring": "fixed",
  },
  "gutter": {
    "runnables": true,
    "folds": true,
  },
  "auto_signature_help": false,
  "which_key": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "cursor_shape": "underline",
  "agent_ui_font_size": 14.0,
  "agent_buffer_font_size": 14.0,
  "ui_font_family": "Monaspace Xenon NF",
  "buffer_font_family": "Monaspace Xenon NF",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "restore_on_startup": "launchpad",
  "session": {
    "restore_unsaved_buffers": true,
  },
  "terminal": {
    "option_as_meta": true,
    "copy_on_select": true,
    "cursor_shape": "underline",
    "font_weight": 300,
  },
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "ui_font_size": 15.0,
  "buffer_font_size": 13.0,
  "theme": "One Dark Pro Max",
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
        },
      },
    },
  },
}
