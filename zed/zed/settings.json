// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "languages": {
    "Markdown": {
      "remove_trailing_whitespace_on_save": true,
      "format_on_save": "on"
    }
  },
  "text_rendering_mode": "platform_default",
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "x_ai",
      "model": "grok-code-fast-1",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "default_width": 300.0,
  },
  "agent_buffer_font_size": 14.0,
  "ui_font_weight": 300.0,
  "buffer_font_weight": 300.0,
  "project_panel": {
    "default_width": 300.0,
  },
  "tabs": {
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": false,
  },
  "use_smartcase_search": true,
  "indent_guides": {
    "coloring": "fixed",
  },
  "gutter": {
    "folds": false,
  },
  "auto_signature_help": false,
  "which_key": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "cursor_shape": "underline",
  "agent_ui_font_size": 14.0,
  "ui_font_family": "Monaspace Xenon",
  "buffer_font_family": "Monaspace Xenon",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "restore_on_startup": "launchpad",
  "session": {
    "restore_unsaved_buffers": true,
  },
  "terminal": {
    "cursor_shape": "underline",
    "font_weight": 300,
  },
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "theme": "One Dark Pro Max",
}
