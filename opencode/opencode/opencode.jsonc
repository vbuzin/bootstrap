{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "agent": {
    "plan": { "disable": true },
    "build": { "disable": true },
  },
  "compaction": {
    "auto": true,
    "prune": true,
  },
  "provider": {
    "xai": {
      "options": {
        "apiKey": "{env:XAI_API_KEY}",
      },
    },
  },
}
