{
  "$schema": "https://opencode.ai/config.json",

  // Plan is the plan-side primary agent — conversation, exploration,
  // planning. Tab switches to Build when ready to execute.
  "default_agent": "plan",

  "compaction": {
    "auto": true,
    "prune": true,
  },
  "provider": {
    "xai": {
      "options": {
        "apiKey": "{env:XAI_API_KEY}",
      },
    },
  },
}
