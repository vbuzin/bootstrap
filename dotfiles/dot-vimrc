hi VertSplit guifg=#212121 guibg=#080909 " Vertical split separator
hi Visual guibg=#2c313a " Visual selection background
hi WarningMsg guifg=#e5c07b guibg=#080909

" -- Statusline ----------------------------------------------------------------
set laststatus=2

set statusline=
set statusline+=%7*\[%n]                                  " Buffer number
set statusline+=%1*\ %<%t\                                " File + path
set statusline+=%2*\ %y\                                  " FileType
set statusline+=%3*\ %{''.(&fenc!=''?&fenc:&enc).''}      " Encoding
set statusline+=%3*\ %{(&bomb?\",BOM\":\"\")}\            " Encoding2 (BOM)
set statusline+=%4*\ %{&ff}\                              " FileFormat (dos/unix..)
set statusline+=%8*\ %=\ row:%l/%L\ (%03p%%)\             " Rownumber/total (%)
set statusline+=%9*\ col:%03c\                            " Colnr
set statusline+=%0*\ \ %m%r%w\ %P\ \                      " Modified? Readonly? Top/bot (last segment)

" Statusline highlight groups
" Statusline highlight groups (One Dark Pro Max)
highlight User1 guifg=#61afef guibg=#080909  " Blue on StatusLine Background
highlight User2 guifg=#7F838C guibg=#080909  " Comment-like color on StatusLine Background
highlight User3 guifg=#7F838C guibg=#080909  " Comment-like color on StatusLine Background
highlight User4 guifg=#7F838C guibg=#080909  " Comment-like color on StatusLine Background
highlight User7 guifg=#abb2bf guibg=#080909  " Main foreground on StatusLine Background
highlight User8 guifg=#abb2bf guibg=#080909  " Main foreground on StatusLine Background
highlight User9 guifg=#abb2bf guibg=#080909  " Main foreground on StatusLine Background
highlight User0 guifg=#abb2bf guibg=#080909  " Main foreground on StatusLine Background

" Ensure transparency at all levels (fix background issue)
hi clear Normal
hi clear StatusLine
hi clear StatusLineNC

