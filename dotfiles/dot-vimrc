" UI Elements
hi CursorLine guibg=#0d0f0f gui=NONE cterm=NONE " Slightly lighter background for cursor line
hi CursorLineNr guifg=#61afef guibg=#0d0f0f cterm=NONE " Accent color for line number on cursor line
